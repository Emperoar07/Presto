# =============================================================================
# DEPLOYMENT MODE
# =============================================================================
# Set to 'true' for production/mainnet deployment
# This affects the network badge display (Testnet vs Live)
NEXT_PUBLIC_PRODUCTION_MODE=false

# Wallet Private Key for Deployment
PRIVATE_KEY=your_private_key_here

# RPC URL (Optional - Hardhat config uses defaults but you might want custom)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# API Key for verification (Optional)
BASESCAN_API_KEY=your_basescan_api_key_here

# =============================================================================
# Contract Addresses (Override defaults from src/config/contracts.ts)
# =============================================================================
# Global override (applies to all chains)
# NEXT_PUBLIC_HUB_AMM_ADDRESS=0x...

# Chain-specific overrides
# NEXT_PUBLIC_HUB_AMM_ADDRESS_31337=0x...  # Hardhat local
# NEXT_PUBLIC_HUB_AMM_ADDRESS_42431=0x...  # Tempo Testnet
# NEXT_PUBLIC_HUB_AMM_ADDRESS_84532=0x...  # Base Sepolia

# WalletConnect Project ID (for Frontend)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Conduit Tempo RPC (preferred)
NEXT_PUBLIC_CONDUIT_TEMPO_RPC_URL=https://YOUR_CONDUIT_TEMPO_RPC

# Optional: Additional RPCs (comma-separated)
TEMPO_RPC_URLS=https://YOUR_CONDUIT_TEMPO_RPC,https://fallback.rpc

# Optional: Base Sepolia RPC override
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Tenderly Configuration
TENDERLY_ACCESS_KEY=your_tenderly_access_key
TENDERLY_USER=your_tenderly_username
TENDERLY_PROJECT=your_tenderly_project_slug

# ZeroDev (smart accounts / gas sponsorship)
NEXT_PUBLIC_ZERODEV_PROJECT_ID=your_zerodev_project_id
ZERODEV_SERVER_API_KEY=your_zerodev_server_api_key

# Blockaid (transaction security)
BLOCKAID_API_KEY=your_blockaid_api_key
BLOCKAID_BASE_URL=https://api.blockaid.io

# Turnkey (embedded wallets)
NEXT_PUBLIC_TURNKEY_ORGANIZATION_ID=your_turnkey_org_id
NEXT_PUBLIC_TURNKEY_RP_ID=your_rp_id
NEXT_PUBLIC_TURNKEY_RP_NAME=your_rp_name
# Optional: Protect /api/simulate
SIMULATE_API_KEY=your_simulate_api_key

# Optional: Distributed rate limiting via Upstash
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Optional: Show order debug panel in UI
NEXT_PUBLIC_DEBUG_ORDERS=false

# USYC Rewards contract (Arc Testnet) — set after running deploy-usyc-rewards script
NEXT_PUBLIC_USYC_REWARDS_ADDRESS=0x...
